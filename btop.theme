# Main background, empty for terminal default, need to be empty if you want transparent background
theme[main_bg]=""

# Main text color
theme[main_fg]="#4b515b"

# Title color for boxes
theme[title]="#c3c8d0"

# Highlight color for keyboard shortcuts
theme[hi_fg]="#ad2222"

# Background color of selected item in processes box
theme[selected_bg]="#ad2222"

# Foreground color of selected item in processes box
theme[selected_fg]="#c3c8d0"

# Color of inactive/disabled text
theme[inactive_fg]="#2b2f37"

# Misc colors for processes box including mini cpu graphs, details memory graph and details status text
theme[proc_misc]="#ad2222"

# Box outline and divider line color
theme[cpu_box]="#9e1a1a"
theme[mem_box]="#2b2f37"
theme[net_box]="#2b2f37"
theme[proc_box]="#2b2f37"
theme[div_line]="#4b515b"

# Gradient for all meters and graphs
theme[temp_start]="#d12b2b"
theme[temp_mid]="#ad2222"
theme[temp_end]="#9e1a1a"


theme[cpu_start]="#8f949c"
theme[cpu_mid]="#ad2222"
theme[cpu_end]="#9e1a1a"


theme[free_start]="#8f949c"
theme[free_mid]="#d12b2b"
theme[free_end]="#9e1a1a"


theme[cached_start]="#8f949c"
theme[cached_mid]="#d12b2b"
theme[cached_end]="#d12b2b"


theme[available_start]="#8f949c"
theme[available_mid]="#d12b2b"
theme[available_end]="#9e1a1a"


theme[used_start]="#8f949c"
theme[used_mid]="#d12b2b"
theme[used_end]="#9e1a1a"


theme[download_start]="#8f949c"
theme[download_mid]="#d12b2b"
theme[download_end]="#ad2222"


theme[upload_start]="#8f949c"
theme[upload_mid]="#d12b2b"
theme[upload_end]="#ad2222"
